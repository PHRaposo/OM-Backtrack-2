l 1))) (when (fboundp (quote set-active)) (set-active box nil)) box) (let ((box (om-load-boxcomment "comment 4" (om-make-point 289 54) (quote "Evaluate one of the methods here$to get the results.") "" (om-make-point 121 570) nil (om-make-color 0 0 0) (om-make-font "Verdana" 13.999999999999999D0 :family "Verdana" :style (quote (:plain)) :mode (quote nil))))) (when (fboundp (quote set-active)) (set-active box nil)) box) (let ((box (om-load-boxcomment "comment" (om-make-point 729 414) (quote "The PRINT-VALUES method and the concept of a NONDETERMINISTIC PATCH$was developed in the first version of OM-BACKTRACK, for Openmusic 4.$$PRINT-VALUES opens a new window, the NONDETERMINISTIC LISTENER, where we$can select which value we want. It is also possible to use OM objects like NOTE,$CHORD, CHORD-SEQ, etc. as an output value. The listener will show then the$editor of the object.$$The NONDETERMINISTIC PATCH is a OM patch evaluated using SCREAMER::DEFUN.$Then, the result is a nondeterministic function. In this version of the library, we have$two options:$$- Create a patch as a nondeterministic function [A];$$- Convert the output of a nondeterministic patch into a deterministic one. This can be$accomplished by using one of the valuation methods inside the patch [B].$$- Multiple outputs work correctly when all of them are deterministic [C].  However,$combining deterministic and nondeterministic outputs can lead to unpredictable$results [D]. In the example, the eval-once mode is used to prevent multiple evaluations$of each output. Note that the second output (all values of an-integer-between 0 and 10)$is repeated six times - once for each possible value of a-member-of (0, 1, 2, 3, 4, 5).") "" (om-make-point 663 0) nil (om-make-color 0 0 0) (om-make-font "Verdana" 13.999999999999999D0 :family "Verdana" :style (quote (:plain)) :mode (quote nil))))) (when (fboundp (quote set-active)) (set-active box nil)) box) (let ((box (om-load-boxcall (quote abstraction) "nondeterministic-patch"